// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  walletAddress String    @unique
  displayName   String?
  email         String?
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wallets       Wallet[]
  wills         Will[]       @relation("OwnerWills")
  transactions  Transaction[]
  reminders     Reminder[]
}

model Wallet {
  id            String   @id @default(cuid())
  userId        String
  walletAddress String   @unique
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Will {
  id                       String    @id @default(cuid())
  onchainWillId            Int?
  ownerUserId              String?
  ownerWallet              String
  beneficiaryWallet        String
  asset                    String
  amount                   String
  unlockTime               DateTime
  heartbeatInterval        Int
  lastHeartbeat            DateTime?
  status                   String    @default("ACTIVE")
  createTxHash             String?
  heartbeatTxHash          String?
  claimTxHash              String?
  cancelTxHash             String?
  changeBeneficiaryTxHash  String?
  stellarExplorerUrl       String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  ownerUser                User?         @relation("OwnerWills", fields: [ownerUserId], references: [id])
  transactions             Transaction[]
  reminders                Reminder[]

  @@index([ownerWallet])
  @@index([beneficiaryWallet])
  @@index([onchainWillId])
}

model Transaction {
  id                String   @id @default(cuid())
  userId            String?
  willId            String?
  walletAddress     String
  type              String
  txHash            String
  stellarExplorerUrl String
  status            String   @default("SUCCESS")
  createdAt         DateTime @default(now())

  user              User?    @relation(fields: [userId], references: [id])
  will              Will?    @relation(fields: [willId], references: [id])

  @@index([walletAddress])
  @@index([willId])
}

model Reminder {
  id            String   @id @default(cuid())
  userId        String?
  willId        String
  email         String
  reminderTime  DateTime
  sent          Boolean  @default(false)
  createdAt     DateTime @default(now())

  user          User?    @relation(fields: [userId], references: [id])
  will          Will     @relation(fields: [willId], references: [id])

  @@index([willId])
}
